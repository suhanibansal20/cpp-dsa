/*
----------------------------------------------------
Problem : Two Sum II 
Platform : LeetCode (167)
Difficulty : Medium
Topic : Arrays

Approach:
Two pointers from start and end.

Time Complexity : O(n)
Space Complexity : O(1)
----------------------------------------------------
*/

#include<bits/stdc++.h>
using namespace std;

class Solution {
public:
    vector<int> twoSum(vector<int>& numbers, int target) {
        vector<int>res;
        int i=0;
        int j=numbers.size()-1;
        while(i<=j)
        {
            if(numbers[i]+numbers[j]>target)
            {
                j--;
            }
            else if(numbers[i]+numbers[j]<target)
            {
                i++;
            }
            else{
                res.push_back(i+1);
                res.push_back(j+1);
                break;
            }
        }
        return res;
    }
};
