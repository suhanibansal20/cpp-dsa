/*
----------------------------------------------------
Problem : Sort Colors
Platform : LeetCode 
Difficulty : Medium
Topic : Arrays

Approach:
Use 3 pointers for this l for 0,m for 1 and h for 2.

Time Complexity : O(n)
Space Complexity : O(1)
----------------------------------------------------
*/

#include<bits/stdc++.h>
using namespace std;


class Solution {
public:
    void sortColors(vector<int>& nums) {
        int l=0;
        int m=0;
        int h=nums.size()-1;
        
        while(m<=h){
            if(nums[m]==2){
                swap(nums[h],nums[m]);
                h--;
                
            }
            else if(nums[m]==0){
                swap(nums[l],nums[m]);
                m++;
                l++;
            }
            else{
                m++;
            }
        }
        
        
        
        
            }
};
