/*
----------------------------------------------------
Problem : Segregate 0s and 1s
Platform : GFG
Difficulty : Easy
Topic : Arrays

Approach:
Use 2pointers, with same end.

Time Complexity : O(n)
Space Complexity : O(1)
----------------------------------------------------
*/

#include<bits/stdc++.h>
using namespace std;

class Solution {
  public:
    void segregate0and1(vector<int> &arr) {
        // code here
        int l=0;
        int m=0;
        while(m!=arr.size()){
            if(arr[m]==0){
                swap(arr[l],arr[m]);
                l++;
                m++;
            }
            else{
                m++;
            }
        }
    }
};
