/*
----------------------------------------------------
Problem : Binary subarrays with sum
Platform : LeetCode (930)
Difficulty : Medium
Topic : Arrays, HashMap

Approach:
Use a Hashmap to store freq of previous ps.

Time Complexity : O(n)
Space Complexity : O(n)
----------------------------------------------------
*/

#include<bits/stdc++.h>
using namespace std;

class Solution {
public:
    int numSubarraysWithSum(vector<int>& nums, int k) {
        unordered_map<int,int> mp;
        mp[0]++;
        int ps=0;
        int ct=0;
        for(int i=0;i<nums.size();i++){
            ps+=nums[i];
            if(mp.count(ps-k)){
                ct+=mp[ps-k];
            }
            mp[ps]++;
        }
return ct;
    }
};
