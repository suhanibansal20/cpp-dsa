    }
};
*/

class Solution {
  public:
    int lengthOfLoop(Node *head) {
        // code here
        Node* slow=head;
       
        Node* fast=head;
        
        
        while(fast && fast->next!=NULL){
            slow=slow->next;
            fast=fast->next->next;
            
            if(slow==fast){
                fast=head;
                
                while(slow!=fast){
                    slow=slow->next;
                    fast=fast->next;
                   
                    
                    
                }
               
            
            int ct=1;
            fast=fast->next;
            while(fast!=slow){
                ct++;
                fast=fast->next;
            }
            return ct;}
            
        }
        return 0;
    }
};
