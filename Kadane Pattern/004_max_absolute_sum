
/*
----------------------------------------------------
Problem : Max absolute sum
Platform : LeetCode (1749)
Difficulty : Medium
Topic : Arrays

Approach:
Max will be of either of least subarray sum or max subarray sum, take abs of min and maintain ans for the best one .

Time Complexity : O(n)
Space Complexity : O(1)
----------------------------------------------------
*/

#include<bits/stdc++.h>
using namespace std;

class Solution {
public:
    int maxAbsoluteSum(vector<int>& nums) {
        int s=0;
        int ans=0;
        int s1=0;
        for(int i=0;i<nums.size();i++){
        
            s=max(nums[i],s+nums[i]);
           s1=min(nums[i],s1+nums[i]);
            ans=max(max(s,abs(s1)),ans);
        }
        return ans;
    }
};
