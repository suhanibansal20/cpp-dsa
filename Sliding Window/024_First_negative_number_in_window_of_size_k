/*
----------------------------------------------------
Problem : First Negative in Window of Size of K
Platform : GFG
Difficulty : Medium
Topic : Arrays, deque

Approach:
Monotonic sliding window pattern 

Time Complexity : O(n)
Space Complexity : O(1)
----------------------------------------------------
*/

#include<bits/stdc++.h>
using namespace std;

class Solution {
  public:
    vector<int> firstNegInt(vector<int>& arr, int k) {
        // code here
        vector<int> ans;
        deque<int> dq;
        for(int i=0;i<arr.size();i++){
            
            
            
            
            
            
           if(arr[i]<0){
               dq.push_back(i);
               
           }
           
            
            
            if(dq.front()<=i-k){
                dq.pop_front();
            }
            
            
            if(i>=k-1){
                if(dq.empty()){
                    ans.push_back(0);
                    dq.push_back(0);
                }
                else{
                ans.push_back(arr[dq.front()]);}
            }
        }
        return ans;
    }
};
