/*
----------------------------------------------------
Problem : Longest Substring Without Repeating Characters
Platform : LeetCode (3)
Difficulty : Medium
Topic : Arrays, Set

Approach:
variable sliding window, hashmap to track distinct elemnts.

Time Complexity : O(n)
Space Complexity : O(n)
----------------------------------------------------
*/

#include<bits/stdc++.h>
using namespace std;

class Solution {
public:
    int lengthOfLongestSubstring(string s) {
        int l=0;
        unordered_map<int,int> freq;
        string ans="";
    
        int m=0;
    
        for(int i=0;i<s.size();i++){
        while(freq[s[i]-'a']==1){
            ans.erase(l,0);
            freq[s[l]-'a']--;
            
            l++;
           

        
        }
        ans+=s[i];
        freq[s[i]-'a']++;

   
        m=max(m,i-l+1);}
        return m;
    }
};
