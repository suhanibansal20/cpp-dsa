/*
----------------------------------------------------
Problem :Subarray Product Less Than K
Platform : LeetCode (713)
Difficulty : Medium
Topic : Arrays

Approach:
Sliding window variable pattern.

Time Complexity : O(n)
Space Complexity : O(1)
----------------------------------------------------
*/

#include<bits/stdc++.h>
using namespace std;

class Solution {
public:
    int numSubarrayProductLessThanK(vector<int>& nums, int k) {
        int l=0;
        int r=0;
        int p=1;
        int ct=0;
        if(k<=1){
            return 0;
        }
        for(r=0;r<nums.size();r++){
            p *= nums[r];
            
     
            while(p>=k){
           p /= nums[l];
           l++;
            }
              
              if(p<k){ct += r-l+1;}
        }
        return ct;
    }
};
