/*
----------------------------------------------------
Problem : Substrings of Size Three with Distinct Characters (1876)
Platform : LeetCode
Difficulty : Easy
Topic : Arrays

Approach:
Using sliding windows.

Time Complexity : O(n)
Space Complexity : O(1)
----------------------------------------------------
*/

#include<bits/stdc++.h>
using namespace std;

class Solution {
public:
    int countGoodSubstrings(string s) {
        int ct=0;
        bool flag=true;
        if(s.size() < 3)
    return 0;

      if(s[0]!=s[1] && s[1]!=s[2] && s[2]!=s[0] ){
        ct++;
      }
            
        
        for(int i=3;i<s.size();i++){
            if(s[i]==s[i-1] || s[i]==s[i-2] || s[i-1]==s[i-2]){
           continue;
            }
            ct++;
        }
        return ct;
    }
};
