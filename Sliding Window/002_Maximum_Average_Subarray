/*
----------------------------------------------------
Problem : Maximum Average Subarray I
Platform : LeetCode (643)
Difficulty : Easy
Topic : Arrays

Approach:
Use sliding window.

Time Complexity : O(n)
Space Complexity : O(1)
----------------------------------------------------
*/

#include<bits/stdc++.h>
using namespace std;
class Solution {
public:
    double findMaxAverage(vector<int>& nums, int k) {
        double av=0;
        double s=0;
        for(int i=0;i<k;i++)
        {
             s+=nums[i];
        }
        av=s/k;
        double m=av;
        for(int i=k;i<nums.size();i++)
        {
            s+= nums[i]-nums[i-k];
            av=s/k;
            m=max(m,av);
        }
        return m;
    }
};
