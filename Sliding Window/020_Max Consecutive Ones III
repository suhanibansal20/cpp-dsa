/*
----------------------------------------------------
Problem : Max Consecutive Ones III
Platform : LeetCode (1004)
Difficulty : Medium
Topic : Arrays

Approach:
Use sliding window.

Time Complexity : O(n)
Space Complexity : O(1)
----------------------------------------------------
*/

#include<bits/stdc++.h>
using namespace std;

class Solution {
public:
    int longestOnes(vector<int>& nums, int k) {

        int left = 0;
        int zeroCount = 0;
        int ans = 0;

        for (int right = 0; right < nums.size(); right++) {

            if (nums[right] == 0)
                zeroCount++;

            while (zeroCount > k) {

                if (nums[left] == 0)
                    zeroCount--;

                left++;
            }

            ans = max(ans, right - left + 1);
        }

        return ans;
    }
};
