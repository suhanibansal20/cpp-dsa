/*
----------------------------------------------------
Problem : Permutation In String
Platform : LeetCode (567)
Difficulty : Medium 
Topic : Strings, Arrays

Approach:
Use sliding window pattern and freq table to maintain freq of characters (same how anagrams was solved).

Time Complexity : O(n)
Space Complexity : O(1)
----------------------------------------------------
*/

#include<bits/stdc++.h>
using namespace std;

class Solution {
public:
    bool checkInclusion(string s1, string s2) {
       
       vector<int>freq(26,0);
       if(s1.size()>s2.size()){return false;}

       for(int i=0;i<s1.size();i++){
        freq[s1[i]-'a']++;
        freq[s2[i]-'a']--;

       } 
       if(freq==vector(26,0)){
        return true;
       }
       for(int i=s1.size();i<s2.size();i++){
        freq[s2[i]-'a']--;
        freq[s2[i-s1.size()]-'a']++;
        if(freq==vector(26,0)){
            return true;
        }
       }
       return false;
    }
};
