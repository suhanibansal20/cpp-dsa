#include<bits/stdc++.h>
using namespace std;

class Solution {
public:
    int maximumUniqueSubarray(vector<int>& nums) {
        int l=0;
        set<int>s;
        int sum=0;
        int m=0;
        int left=0;
       

        for(int i=0;i<nums.size();i++)
        {
          
        while(s.find(nums[i])!=s.end()){
            sum -= nums[left];
        s.erase(nums[left]);
            left++;
            
                         
        }
    s.insert(nums[i]);
        sum+=nums[i];
            
        m=max(m,sum);
        }  
        return m; 
         }
};
