/*
----------------------------------------------------
Problem : Number of Sub-arrays of Size K and Average Greater than or Equal to Threshold
Platform : LeetCode (1343)
Difficulty : Medium
Topic : Arrays

Approach:
Use sliding window.

Time Complexity : O(n)
Space Complexity : O(1)
----------------------------------------------------
*/

#include<bits/stdc++.h>
using namespace std;

class Solution {
public:
    int numOfSubarrays(vector<int>& arr, int k, int threshold) {
        int s=0;
        int av=0;
        int ct=0;
        for(int i=0;i<k;i++)
        {
            s+= arr[i];
        }
        av=s/k;
        if(av>=threshold)
        {
            ct++;
        }
        for(int i=k;i<arr.size();i++)
        {
            s+=arr[i]-arr[i-k];
            av=s/k;
            if(av>=threshold)
        {
            ct++;
        }

        }
        return ct;
    }
};
