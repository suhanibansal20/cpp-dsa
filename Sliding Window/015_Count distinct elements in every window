/*
----------------------------------------------------
Problem : Count distinct elements in every window
Platform : GFG
Difficulty : Medium
Topic : Arrays

Approach:
Use sliding window but use hashmap so that it can store large values.

Time Complexity : O(n)
Space Complexity : O(n)
----------------------------------------------------
*/

#include<bits/stdc++.h>
using namespace std;

class Solution {
  public:
    vector<int> countDistinct(vector<int> &arr, int k) {
        // code here
        vector<int>res;
         unordered_map<int,int>freq;
        int ct=0;
        if(k>arr.size() || k<=0){
            return res;
        }
        for(int i=0;i<k;i++){
            
            freq[arr[i]]++;
                if(freq[arr[i]]==1){
                    ct++;
                }
            }
        
        res.push_back(ct);
        
        for(int i=k;i<arr.size();i++){
           
            freq[arr[i-k]]--;
            if(freq[arr[i-k]]==0){
                ct--;
            }
            
            freq[arr[i]]++;
            if(freq[arr[i]]==1){
                ct++;
            }
            
            
          
            res.push_back(ct);
            
            
        }
        return res;
    }
};
