/*
----------------------------------------------------
Problem : Grumpy Bookstore Owner
Platform : LeetCode (1052)
Difficulty : Medium
Topic : Arrays

Approach:
Use sliding window, sum of all possible satisified ones, then the extra ones are calc usin sliding window approach.

Time Complexity : O(n)
Space Complexity : O(1)
----------------------------------------------------
*/

#include<bits/stdc++.h>
using namespace std;

class Solution {
public:
    int maxSatisfied(vector<int>& customers, vector<int>& grumpy, int minutes) {
        int base=0;
        for(int i=0;i<customers.size();i++){
            if(grumpy[i]==0){
                base+=customers[i];
            }
        }
        int extra=0;
        for(int i=0;i<minutes;i++){
            if(grumpy[i]==1){
                extra+= customers[i];
            }
        }
        int best=extra;
         for(int i=minutes;i<grumpy.size();i++){
            if(grumpy[i]==1){
                extra+=customers[i];
            }
            if(grumpy[i-minutes]==1){
                extra-=customers[i-minutes];
            }
            best=max(best,extra);
         }


        return best+base;




    }
};
