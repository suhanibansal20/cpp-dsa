/*
----------------------------------------------------
Problem : Maximum Number of Vowels in a Substring of Given Length
Platform : LeetCode (1456)
Difficulty : Medium
Topic : Strings

Approach:
Use a sliding wndow to maintain count of vowels .

Time Complexity : O(n)
Space Complexity : O(1)
----------------------------------------------------
*/

#include<bits/stdc++.h>
using namespace std;

class Solution {
public:
    int maxVowels(string s, int k) {
        int ct=0;
        int res=0;
        for(int i=0;i<k;i++){
            if(s[i]=='a'|| s[i]== 'e'|| s[i]=='i'|| s[i]=='o'|| s[i]== 'u'){
                ct++;
            }
  
        }
        res=ct;
        for(int i=k;i<s.size();i++){
            
            if(s[i]=='a'|| s[i]== 'e'|| s[i]=='i'|| s[i]=='o'|| s[i]== 'u'){
                ct++;
            }
            
            
                        if(s[i-k]=='a'|| s[i-k]== 'e'|| s[i-k]=='i'|| s[i-k]=='o'|| s[i-k]== 'u')
                {
                    ct--;
                }
                     res=max(res,ct);
        }
        return res;
    }
};
